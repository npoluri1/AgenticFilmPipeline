FROM node:20-alpine AS web-builder
WORKDIR /app
COPY web/package.json web/package-lock.json* ./
RUN npm install
COPY web/ .
RUN npm run build

FROM python:3.11-slim
WORKDIR /app

RUN pip install --no-cache-dir fastapi uvicorn pyyaml pydantic httpx rich

COPY . .

COPY --from=web-builder /app/out /app/web/out

EXPOSE 8080 3000

CMD uvicon src.web.server:app --host 0.0.0.0 --port 8080 & cd web && npx next start -p 3000
